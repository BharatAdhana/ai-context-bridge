{
  "name": "aibridge-context",
  "version": "2.3.2",
  "description": "Zero-config CLI that auto-generates an AI briefing file for any project — tracks code changes with real diffs, errors, fixes, file structure, API routes and dependencies. One command: npx aibridge-context start",
  "main": "./index.js",
  "bin": {
    "aibridge-context": "./bin/cli.js",
    "aibridge": "./bin/cli.js",
    "ai-context": "./bin/cli.js"
  },
  "files": [
    "bin",
    "core",
    "server",
    "templates",
    "utils",
    "index.js",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/cli.js start",
    "init:context": "node ./bin/cli.js init",
    "update:context": "node ./bin/cli.js update"
  },
  "keywords": [
    "ai",
    "context",
    "cli",
    "watcher",
    "express",
    "developer-tools",
    "git",
    "briefing",
    "diff",
    "changelog"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^5.1.0"
  }
}
